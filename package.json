{
  "name": "setup-swift",
  "version": "1.13.0",
  "private": true,
  "type": "module",
  "description": "Setup Swift environment.",
  "main": "lib/main.js",
  "author": "Soumya Ranjan Mahunt",
  "license": "MIT",
  "homepage": "https://github.com/SwiftyLab/setup-swift#readme",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SwiftyLab/setup-swift.git"
  },
  "bugs": {
    "url": "https://github.com/SwiftyLab/setup-swift/issues"
  },
  "keywords": [
    "swift",
    "setup",
    "setup-swift",
    "actions",
    "github-actions",
    "ci"
  ],
  "scripts": {
    "prepare": "node -e \"import('./.github/utils/update_metadata.js').then(m => m.fetch())\" && npm run build",
    "build": "tsc",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "depcheck --ignores ts-node,globals,@eslint/js,@eslint/eslintrc,@vitest/coverage-v8 && eslint src/**/*.ts && prettier --check \"**/*.ts\"",
    "package": "esbuild lib/main.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs",
    "test": "vitest run --coverage",
    "all": "npm run format && npm run build && npm run lint && npm run package && npm run test"
  },
  "dependencies": {
    "@actions/cache": "^4.1.0",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^2.0.2",
    "getos": "^3.2.1",
    "glob": "^13.0.0",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "plist": "^3.1.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.7.1",
    "@types/getos": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.23",
    "@types/plist": "^3.0.5",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.1.1",
    "conventional-changelog-conventionalcommits": "^7.0.0",
    "depcheck": "^1.4.7",
    "esbuild": "0.27.4",
    "eslint": "^9.35.0",
    "eslint-plugin-vitest": "^0.5.4",
    "nock": "^14.0.10",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}