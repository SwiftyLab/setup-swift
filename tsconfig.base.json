{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noImplicitReturns": true,
    "strictBuiltinIteratorReturn": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "exclude": ["node_modules"]
}
